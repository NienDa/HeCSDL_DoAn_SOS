@model IEnumerable<DoAnCNPM_SOS.Models.GH>

@{
    ViewBag.Title = "Lịch sử vận đơn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <h3 class="fw-bold mb-3 text-uppercase text-primary">LỊCH SỬ GIAO HÀNG (TABLE GH)</h3>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th class="py-3 ps-4">Mã Giao Hàng</th>
                        <th>Mã Hóa Đơn</th>
                        <th>Shipper Phụ Trách</th>
                        <th>Ngày Giao</th>
                        <th>Trạng Thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@item.GHID</td>
                            <td><span class="text-muted">#@item.HDID</span></td>
                            <td>
                                <span class="fw-bold text-dark">@item.NV.TENNV</span>
                            </td>
                            <td>@String.Format("{0:dd/MM/yyyy}", item.NGAYGIAO)</td>
                            <td>
                                @if (item.TRANGTHAI == "ĐÃ GIAO")
                                {
                                    <span class="badge bg-success rounded-pill px-3">ĐÃ GIAO</span>
                                }
                                else if (item.TRANGTHAI == "ĐÃ HỦY")
                                {
                                    <span class="badge bg-danger rounded-pill px-3">ĐÃ HỦY</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark rounded-pill px-3">ĐANG GIAO</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-4">
        <a href="@Url.Action("Index", "Delivery")" class="btn btn-outline-dark fw-bold">
            ← QUAY LẠI ĐIỀU PHỐI
        </a>
    </div>
</div>