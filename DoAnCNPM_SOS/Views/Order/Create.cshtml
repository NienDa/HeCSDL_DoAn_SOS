@{
    ViewBag.Title = "Thanh toán";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang chủ</a></li>
                    <li class="breadcrumb-item active fw-bold" aria-current="page">Thanh toán & Đặt hàng</li>
                </ol>
            </nav>

            @if (TempData["Message"] != null)
            {
                <div class="alert alert-@TempData["Type"] shadow-sm border-0 mb-4 d-flex align-items-center">
                    <div class="fs-2 me-3">
                        @(TempData["Type"].ToString() == "success" ? "🎉" : "⚠️")
                    </div>
                    <div>
                        <h6 class="fw-bold mb-1">Thông báo hệ thống:</h6>
                        <span>@TempData["Message"]</span>
                    </div>
                </div>
            }

            <form action="@Url.Action("SubmitOrder", "Order")" method="post">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-header bg-white border-bottom py-3">
                        <h4 class="fw-bold m-0 text-primary">Xác nhận đơn hàng</h4>
                    </div>

                    <div class="card-body p-4 bg-light">

                        <div class="bg-white p-3 rounded-3 border mb-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center fw-bold me-2" style="width:30px; height:30px;">1</div>
                                <h6 class="fw-bold m-0">Thông tin giao hàng</h6>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="small text-muted fw-bold">Họ và tên:</label>
                                    <input type="text" name="tenKH" class="form-control" placeholder="Nguyễn Văn A" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="small text-muted fw-bold">Số điện thoại:</label>
                                    <input type="text" name="sdt" class="form-control" placeholder="09xxxxxxx" required>
                                </div>
                                <div class="col-12">
                                    <label class="small text-muted fw-bold">Địa chỉ nhận hàng:</label>
                                    <input type="text" name="diaChi" class="form-control" placeholder="Số nhà, đường, quận/huyện..." required>
                                </div>
                            </div>
                        </div>

                        <div class="bg-white p-3 rounded-3 border mb-4">
                            <div class="d-flex align-items-center mb-3">
                                <div class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center fw-bold me-2" style="width:30px; height:30px;">2</div>
                                <h6 class="fw-bold m-0">Sản phẩm</h6>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-8">
                                    <label class="small text-muted fw-bold">Chọn sản phẩm:</label>
                                    @Html.DropDownList("spId", (SelectList)ViewBag.SPID, new { @class = "form-select" })
                                </div>
                                <div class="col-md-4">
                                    <label class="small text-muted fw-bold">Số lượng:</label>
                                    <div class="input-group">
                                        <button class="btn btn-outline-secondary" type="button" onclick="this.parentNode.querySelector('input').stepDown()">-</button>
                                        <input type="number" name="soLuong" class="form-control text-center fw-bold" value="1" min="1" required>
                                        <button class="btn btn-outline-secondary" type="button" onclick="this.parentNode.querySelector('input').stepUp()">+</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card border-0 bg-primary text-white rounded-3">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <small class="d-block opacity-75">Tổng thanh toán dự kiến:</small>
                                    <span class="fw-bold fs-5">Tự động tính toán</span>
                                </div>
                                <button type="submit" class="btn btn-light fw-bold text-primary px-4 py-2 rounded-pill shadow">
                                    ĐẶT HÀNG NGAY
                                </button>
                            </div>
                        </div>

                        <p class="text-center mt-3 small text-muted">
                            By clicking "Đặt hàng ngay", hệ thống sẽ kích hoạt <strong>Transaction</strong> để xử lý đơn hàng và <strong>Trigger</strong> để trừ kho.
                        </p>

                    </div>
                </div>
            </form>
        </div>
    </div>
</div>