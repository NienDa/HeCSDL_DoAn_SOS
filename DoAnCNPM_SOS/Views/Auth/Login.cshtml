@{ ViewBag.Title = "Đăng nhập nội bộ"; Layout = null; }

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container d-flex justify-content-center align-items-center vh-100 bg-light">
    <div class="card shadow p-4" style="width: 400px;">
        <h3 class="text-center fw-bold text-primary mb-4">CỔNG NHÂN VIÊN</h3>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form action="@Url.Action("Login", "Auth")" method="post">
            <div class="mb-3">
                <label>Số điện thoại (NV):</label>
                <input type="text" name="sdt" class="form-control" required placeholder="Nhập SĐT nhân viên trong DB">
            </div>
            <div class="mb-3">
                <label>Mật khẩu:</label>
                <input type="password" name="password" class="form-control" value="123">
                <small class="text-muted">Mặc định: 123</small>
            </div>
            <button type="submit" class="btn btn-primary w-100">Đăng Nhập</button>
        </form>
        <div class="text-center mt-3">
            <a href="@Url.Action("Index", "Home")">← Quay lại trang bán hàng</a>
        </div>
    </div>
</div>
