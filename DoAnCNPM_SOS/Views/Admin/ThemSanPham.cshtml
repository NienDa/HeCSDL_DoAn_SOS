@{ ViewBag.Title = "Thêm Sản Phẩm"; Layout = "~/Views/Shared/_Layout.cshtml"; }
@{
    ViewBag.Title = "ThemSanPham";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">

            <div class="mb-3">
                <a href="@Url.Action("Dashboard", "Admin")" class="text-decoration-none text-muted">
                    &larr; Quay lại Dashboard
                </a>
            </div>

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <div class="card-header bg-primary text-white py-4 text-center">
                    <h4 class="fw-bold mb-0 text-uppercase">
                        <svg width="28" height="28" class="me-2 mb-1" style="fill: currentColor;"><use xlink:href="#plus"></use></svg>
                        Thêm Sản Phẩm Mới
                    </h4>
                    <p class="mb-0 opacity-75 small">Nhập thông tin chi tiết sản phẩm vào hệ thống</p>
                </div>

                <div class="card-body p-5 bg-light">

                    <form action="@Url.Action("ThemSanPham", "Admin")" method="post" enctype="multipart/form-data">

                        <div class="form-floating mb-4">
                            <input type="text" name="tenSP" class="form-control rounded-3" id="floatingName" placeholder="Tên sản phẩm" required>
                            <label for="floatingName">Tên sản phẩm (Ví dụ: Coca Cola)</label>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Danh mục</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0"><svg width="18" height="18"><use xlink:href="#category"></use></svg></span>
                                    @Html.DropDownList("dmspId", (SelectList)ViewBag.DMSPID, new { @class = "form-select border-start-0 ps-0", @style = "border-left:none;" })
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Nhà cung cấp</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0"><svg width="18" height="18"><use xlink:href="#store"></use></svg></span>
                                    @Html.DropDownList("nccId", (SelectList)ViewBag.NCCID, new { @class = "form-select border-start-0 ps-0" })
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted text-uppercase">Hình ảnh sản phẩm</label>
                            <div class="p-3 bg-white border rounded-3 text-center">
                                <input type="file" name="hinhAnh" class="form-control form-control-sm mb-2" accept="image/*" />
                                <small class="text-muted fst-italic d-block">
                                    <span class="text-danger">*</span> Nếu bỏ trống, hệ thống sẽ hiển thị ảnh mặc định:
                                    <img src="/images/default.png" width="30" class="border ms-1" />
                                </small>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Giá bán</label>
                                <div class="input-group input-group-lg">
                                    <input type="number" name="gia" class="form-control fw-bold text-primary" placeholder="0" required />
                                    <span class="input-group-text bg-white text-muted fs-6">VNĐ</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Số lượng nhập kho</label>
                                <div class="input-group input-group-lg">
                                    <input type="number" name="soLuong" class="form-control fw-bold" placeholder="0" required />
                                    <span class="input-group-text bg-white text-muted fs-6">Đơn vị</span>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4 opacity-25">

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow-sm py-3 fw-bold text-uppercase">
                                <svg width="20" height="20" class="me-2 mb-1"><use xlink:href="#plus"></use></svg>
                                Lưu vào Database (Exec USP)
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<svg xmlns="http://www.w3.org/2000/svg" style="display: none;">
    <symbol id="store" viewBox="0 0 24 24">
        <path fill="currentColor" d="M4 4h16a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2zm16 8v9a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-9h2v5a1 1 0 0 0 2 0v-5h4v5a1 1 0 0 0 2 0v-5h4v5a1 1 0 0 0 2 0v-5h2z" />
    </symbol>
</svg>
