@model IEnumerable<DoAnCNPM_SOS.Models.NV>

@{
    ViewBag.Title = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary m-0">QUẢN TRỊ NHÂN SỰ & HỆ THỐNG</h2>
        <span class="badge bg-secondary">Admin Panel</span>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-@TempData["Type"] alert-dismissible fade show shadow-sm" role="alert">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm mb-5">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">👥 DANH SÁCH NHÂN VIÊN</h5>

            <form action="@Url.Action("CapNhatCapBac", "Admin")" method="post" class="d-inline">
                <button type="submit" class="btn btn-warning btn-sm fw-bold text-dark" title="Chạy Cursor cập nhật lại cấp bậc dựa trên lương">
                    <svg width="16" height="16" class="me-1 mb-1"><use xlink:href="#refresh"></use></svg>
                    Cập nhật Cấp Bậc (Cursor)
                </button>
            </form>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Mã NV</th>
                            <th>Họ và Tên</th>
                            <th>Lương cơ bản</th>
                            <th>Cấp bậc (Cursor tính)</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-muted">#@item.NVID</td>
                                <td class="fw-bold text-dark">@item.TENNV</td>
                                <td class="text-success fw-bold">@String.Format("{0:N0}", item.LUONG)</td>
                                <td>
                                    @if (item.CAPBAC == "QUẢN LÝ")
                                    {
                                        <span class="badge bg-danger">@item.CAPBAC</span>
                                    }
                                    else if (item.CAPBAC == "NHÂN VIÊN CHÍNH THỨC" || item.CAPBAC == "NHÂN VIÊN")
                                    {
                                        <span class="badge bg-success">@item.CAPBAC</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.CAPBAC</span>
                                    }
                                </td>
                                <td><span class="badge bg-light text-dark border">Đang làm việc</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <hr class="my-5 border-secondary opacity-25">

    <h4 class="fw-bold text-muted mb-4 mt-5">🛡 TRUNG TÂM AN TOÀN DỮ LIỆU</h4>

    <div class="row g-4">
        <div class="col-md-5">
            <div class="card h-100 border-success shadow-sm">
                <div class="card-header bg-success text-white fw-bold">
                    💾 SAO LƯU (BACKUP)
                </div>
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <p class="text-muted mb-1 small text-uppercase fw-bold">Lần sao lưu gần nhất</p>
                    @if (ViewBag.LastBackupTime != null)
                    {
                        <h2 class="text-success fw-bold">@String.Format("{0:HH:mm:ss}", ViewBag.LastBackupTime)</h2>
                        <span class="badge bg-light text-dark border mb-4">Ngày @String.Format("{0:dd/MM/yyyy}", ViewBag.LastBackupTime)</span>
                    }
                    else
                    {
                        <h4 class="text-muted mb-4">-- Chưa có dữ liệu --</h4>
                    }

                    <form action="@Url.Action("BackupDatabase", "Admin")" method="post">
                        <button type="submit" class="btn btn-success w-100 fw-bold py-3 shadow">
                            <svg width="24" height="24" class="me-2 mb-1" style="fill:currentColor"><use xlink:href="#plus"></use></svg>
                            TẠO BẢN SAO LƯU MỚI
                        </button>
                    </form>
                    <small class="text-muted mt-3 d-block fst-italic">File sẽ lưu tại C:\Backup_SOS</small>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="card h-100 border-warning shadow-sm">
                <div class="card-header bg-warning text-dark fw-bold">
                    ♻️ KHÔI PHỤC (RESTORE)
                </div>
                <div class="card-body">
                    <div class="alert alert-danger py-2 small mb-3">
                        <strong>⚠️ CẢNH BÁO:</strong> Hành động này sẽ XÓA SẠCH dữ liệu hiện tại và thay thế bằng bản backup bạn chọn.
                    </div>

                    <h6 class="fw-bold small text-muted mb-2">DANH SÁCH BẢN SAO LƯU CÓ SẴN:</h6>

                    <div class="list-group overflow-auto" style="max-height: 250px;">
                        @if (ViewBag.BackupFiles != null)
                        {
                            foreach (var file in ViewBag.BackupFiles as List<string>)
                            {
                                <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-2">
                                    <div class="d-flex align-items-center overflow-hidden">
                                        <span class="fs-4 me-2">📦</span>
                                        <div class="text-truncate">
                                            <div class="fw-bold text-dark" style="font-size: 0.9rem;">@file</div>
                                        </div>
                                    </div>

                                    <form action="@Url.Action("ProcessRestore", "Admin")" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn khôi phục không? Dữ liệu mới sẽ mất!');">
                                        <input type="hidden" name="fileName" value="@file" />
                                        <button type="submit" class="btn btn-sm btn-primary fw-bold text-nowrap px-3">
                                            Restore Ngay
                                        </button>
                                    </form>
                                </div>
                            }
                        }
                        @if (ViewBag.BackupFiles == null || (ViewBag.BackupFiles as List<string>).Count == 0)
                        {
                            <div class="text-center p-4 text-muted border rounded bg-light">Chưa có file backup nào.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100 border-success shadow-sm">
            <div class="card-header bg-success text-white fw-bold">
                💰 ĐIỀU CHỈNH GIÁ (USP_TANG_GIA)
            </div>
            <div class="card-body">
                <p class="card-text small text-muted">Thực thi Stored Procedure để cập nhật giá hàng loạt theo danh mục.</p>
                <form action="@Url.Action("TangGia", "Admin")" method="post" class="row g-3 align-items-end">
                    <div class="col-6">
                        <label class="form-label fw-bold small">Chọn Danh mục:</label>
                        <select name="dmspId" class="form-select form-select-sm">
                            <option value="">-- Tất cả --</option>
                            <option value="1">Đồ uống</option>
                            <option value="2">Thực phẩm</option>
                            <option value="3">Trái cây</option>
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-bold small">% Tăng giá:</label>
                        <div class="input-group input-group-sm">
                            <input type="number" name="phanTram" class="form-control fw-bold" value="10">
                            <span class="input-group-text">%</span>
                        </div>
                    </div>
                    <div class="col-12 mt-2">
                        <button type="submit" class="btn btn-success w-100 fw-bold py-2">
                            🚀 THỰC THI (EXEC USP)
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

</div>
</div>

<svg xmlns="http://www.w3.org/2000/svg" style="display: none;">
    <symbol id="refresh" viewBox="0 0 24 24">
        <path fill="currentColor" d="M17.65 6.35A7.958 7.958 0 0 0 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0 1 12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" />
    </symbol>
</svg>
