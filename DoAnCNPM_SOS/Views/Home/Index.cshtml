@model IEnumerable<DoAnCNPM_SOS.Models.SP>

@{
    ViewBag.Title = "Siêu thị Online";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var listCategories = ViewBag.Categories as List<DoAnCNPM_SOS.Models.DMSP>;
}

<section class="py-3" style="background-image: url('/images/banner-1.jpg'); background-size: cover; background-position: center;">
    <div class="container-lg">
        <div class="row justify-content-center py-5">
            <div class="col-md-8 text-center text-white bg-dark bg-opacity-50 p-4 rounded-4">
                <h1 class="display-5 fw-bold">SIÊU THỊ TRỰC TUYẾN SOS</h1>
                <p class="lead">Thực phẩm tươi ngon - Giao hàng tận nơi - Giá cả bình ổn</p>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container-lg">
        <div class="row">

            <div class="col-lg-3 mb-4">

                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-primary text-white fw-bold">
                        <svg width="18" height="18" class="me-1"><use xlink:href="#search"></use></svg> TÌM KIẾM
                    </div>
                    <div class="card-body">
                        <form action="@Url.Action("Index", "Home")" method="get">
                            <div class="input-group">
                                <input type="text" name="searchString" class="form-control" placeholder="Nhập tên sản phẩm..." required>
                                <button class="btn btn-outline-primary" type="submit">Tìm</button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="card shadow-sm border-0">
                    <div class="card-header bg-success text-white fw-bold">
                        <svg width="18" height="18" class="me-1"><use xlink:href="#category"></use></svg> DANH MỤC SẢN PHẨM
                    </div>
                    @{
                        var currentCateId = Request.QueryString["categoryId"];
                    }

                    <div class="list-group list-group-flush">
                        <a href="@Url.Action("Index", "Home")"
                           class="list-group-item list-group-item-action @(string.IsNullOrEmpty(currentCateId) ? "active fw-bold" : "")">
                            ★ Xem tất cả
                        </a>

                        @if (ViewBag.Categories != null)
                        {
                            foreach (var dm in ViewBag.Categories as List<DoAnCNPM_SOS.Models.DMSP>)
                            {
                                bool isActive = currentCateId == dm.DMSPID.ToString();

                                <a href="@Url.Action("Index", "Home", new { categoryId = dm.DMSPID })"
                                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(isActive ? "active fw-bold" : "")">

                                    @dm.TENDM

                                    <span class="badge @(isActive ? "bg-white text-primary" : "bg-light text-dark") rounded-pill">➤</span>
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-9">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold text-dark">
                        @if (ViewBag.Message != null)
                        {
                            <span>@ViewBag.Message</span>
                        }
                        else
                        {
                            <span>Tất cả sản phẩm</span>
                        }
                    </h3>
                    <span class="text-muted">Hiển thị @Model.Count() sản phẩm</span>
                </div>

                @if (Model.Count() == 0)
                {
                    <div class="alert alert-warning text-center">Không tìm thấy sản phẩm nào!</div>
                }
                else
                {
                    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
                        @foreach (var item in Model)
                        {
                            <div class="col">
                                <div class="card h-100 border-0 shadow-sm product-card">

                                    <div class="position-absolute top-0 start-0 m-2 z-2">
                                        @if (item.SOLUONG > 0)
                                        {
                                            <span class="badge bg-success">Còn hàng (@item.SOLUONG)</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Hết hàng</span>
                                        }
                                    </div>

                                    <figure class="text-center p-3 mb-0 bg-light rounded-top">
                                        <a href="@Url.Action("Details", "Product", new { id = item.SPID })">
                                            <img src="/images/@(string.IsNullOrEmpty(item.HINHANH) ? "product-thumb-" + (item.SPID % 10 + 1) + ".png" : item.HINHANH)"
                                                 class="img-fluid" style="height: 180px; object-fit: contain;" alt="@item.TENSP">
                                        </a>
                                    </figure>

                                    <div class="card-body d-flex flex-column">
                                        <h5 class="card-title fs-6 fw-bold">
                                            <a href="@Url.Action("Details", "Product", new { id = item.SPID })" class="text-decoration-none text-dark">
                                                @item.TENSP
                                            </a>
                                        </h5>

                                        <div class="mt-auto">
                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                <span class="text-primary fw-bold fs-5">@String.Format("{0:N0} đ", item.GIA)</span>
                                                <small class="text-muted text-decoration-line-through">@String.Format("{0:N0} đ", item.GIA * 1.2m)</small>
                                            </div>

                                            <div class="d-grid gap-2">
                                                <a href="@Url.Action("Create", "Order")" class="btn btn-primary btn-sm">
                                                    <svg width="16" height="16" class="mb-1"><use xlink:href="#cart"></use></svg> Mua ngay
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</section>