<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Siêu thị SOS</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" type="text/css" href="~/css/vendor.css">
    <link rel="stylesheet" type="text/css" href="~/css/style.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700&family=Open+Sans:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
</head>
<body>

    <svg xmlns="http://www.w3.org/2000/svg" style="display: none;">
    </svg>

    <div class="preloader-wrapper">
        <div class="preloader"></div>
    </div>

    <div class="offcanvas offcanvas-end" id="offcanvasCart">...</div>
    <div class="offcanvas offcanvas-start" id="offcanvasNavbar">...</div>

    <header>
        <div class="container-fluid">
            <div class="row py-3 border-bottom align-items-center">

                <div class="col-sm-4 col-lg-2 text-center text-sm-start d-flex gap-3 justify-content-center justify-content-md-start">
                    <div class="d-flex align-items-center my-3 my-sm-0">
                        <a href="@Url.Action("Index", "Home")" class="text-decoration-none text-dark fw-bold fs-4">
                            SOS MARKET
                        </a>
                    </div>
                    <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNavbar">
                        <svg width="24" height="24"><use xlink:href="#menu"></use></svg>
                    </button>
                </div>

                <div class="col-lg-8 d-none d-lg-block">
                    <ul class="navbar-nav list-unstyled d-flex flex-row gap-3 justify-content-center align-items-center mb-0 fw-bold text-uppercase text-dark">
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "Home")" class="nav-link">Trang chủ</a>
                        </li>

                        @if (Session["User"] != null && Session["Role"].ToString() == "QUẢN LÝ")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-danger border border-danger rounded px-2" href="#" data-bs-toggle="dropdown">
                                    ⚙️ MODULE QUẢN LÝ (ADMIN)
                                </a>
                                <ul class="dropdown-menu shadow">
                                    <li><h6 class="dropdown-header">Quản trị dữ liệu</h6></li>
                                    <li><a class="dropdown-item" href="@Url.Action("NhaCungCap", "Admin")">🏭 Nhà Cung Cấp</a></li>
                                    <li><a class="dropdown-item" href="@Url.Action("ThemSanPham", "Admin")">➕ Thêm Sản Phẩm</a></li>
                                    <li><a class="dropdown-item" href="@Url.Action("ThemDanhMuc", "Admin")">📂 Quản lý Danh Mục (DMSP)</a></li>
                                    <li><a class="dropdown-item" href="@Url.Action("Dashboard", "Admin")">👥 Nhân Sự & Lương</a></li>

                                    <li><hr class="dropdown-divider"></li>
                                    <li><h6 class="dropdown-header">Báo cáo & Nghiệp vụ</h6></li>
                                    <li><a class="dropdown-item" href="@Url.Action("Index", "Delivery")">🚚 Điều phối Giao Hàng</a></li>
                                    <li><a class="dropdown-item" href="@Url.Action("BaoCaoDoanhThu", "Admin")">💰 Báo Cáo Doanh Thu</a></li>

                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item fw-bold text-primary" href="@Url.Action("Create", "Order")">🛒 Test Lập Hóa Đơn</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>

                <div class="col-sm-8 col-lg-2 d-flex gap-3 justify-content-end align-items-center">

                    <a href="@Url.Action("Create", "Order")" class="text-dark position-relative me-2" title="Giỏ hàng">
                        <svg width="24" height="24"><use xlink:href="#cart"></use></svg>
                    </a>

                    @if (Session["User"] != null)
                    {
                        // ĐÃ ĐĂNG NHẬP
                        <div class="dropdown">
                            <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle text-dark fw-bold" data-bs-toggle="dropdown">
                                <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width:35px; height:35px;">
                                    @(Session["TenNV"] != null ? Session["TenNV"].ToString().Substring(0, 1) : "U")
                                </div>
                                <span class="d-none d-md-block small">@Session["TenNV"]</span>
                            </a>

                            <ul class="dropdown-menu shadow dropdown-menu-end">
                                <li><h6 class="dropdown-header">Vai trò: @Session["Role"]</h6></li>

                                @if (Session["Role"].ToString() != "QUẢN LÝ")
                                {
                                    <li><a class="dropdown-item" href="@Url.Action("MyTasks", "Delivery")">📦 Nhiệm vụ của tôi</a></li>
                                }

                                @if (Session["Role"].ToString() == "QUẢN LÝ")
                                {
                                    <li><a class="dropdown-item" href="@Url.Action("Dashboard", "Admin")">⚙️ Vào trang Quản Trị</a></li>
                                }

                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="@Url.Action("Logout", "Auth")">Đăng xuất</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="@Url.Action("Login", "Auth")" class="btn btn-outline-dark btn-sm rounded-pill text-nowrap px-3">
                            🔐 Đăng nhập
                        </a>
                    }
                </div>

            </div>
        </div>
    </header>

    @RenderBody()

    <footer class="py-5">
    </footer>
    <div id="footer-bottom">
    </div>

    <script src="~/js/jquery-1.11.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@9/swiper-bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/plugins.js"></script>
    <script src="~/js/script.js"></script>

    @* Dòng này để các View con có thể chèn thêm script riêng nếu cần *@
    @RenderSection("Scripts", required: false)
</body>
</html>